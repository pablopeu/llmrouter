# ============================================
# LLMRouter - API Keys Configuration
# ============================================
# Copy this file as .env and fill in your values.
#   cp .env.example .env
#   chmod 600 .env
#
# NEVER commit .env with real keys.

# --- Z.AI (Anthropic-compatible proxy) ---
ZAI_API_KEY=your-zai-api-key
ZAI_API_BASE=https://api.z.ai/api/anthropic

# --- DeepSeek (OpenAI-compatible API) ---
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- LiteLLM Proxy ---
# Local key to authenticate requests to the proxy.
# Claude Code sends this as ANTHROPIC_AUTH_TOKEN.
LITELLM_MASTER_KEY=sk-local-llmrouter-change-me

# --- Real model names ---
# Adjust according to the models available in each account.
# ZAI_MODEL_FOR_SONNET: GLM model available via Z.AI (Anthropic format)
ZAI_MODEL_FOR_SONNET=glm-5.1
# DEEPSEEK_MODEL_FOR_OPUS: most powerful DeepSeek model available
DEEPSEEK_MODEL_FOR_OPUS=deepseek/deepseek-v4-pro
# DEEPSEEK_MODEL_FOR_HAIKU: fastest/cheapest DeepSeek model available
DEEPSEEK_MODEL_FOR_HAIKU=deepseek/deepseek-v4-flash

# --- Network ---
ROUTER_HOST=127.0.0.1
ROUTER_PORT=4000

# --- Codex CLI ---
# Codex uses the Responses API. The local adapter filters native tools that
# LiteLLM cannot translate to Anthropic-compatible backends.
CODEX_ADAPTER_HOST=127.0.0.1
CODEX_ADAPTER_PORT=4001
CODEX_DEFAULT_MODEL=deepseek-opus
CODEX_REASONING_EFFORT=xhigh
CODEX_DISABLE_THINKING=1
