#!/usr/bin/env bash
# codex-mix: Lanza OpenAI Codex CLI apuntando al router local.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTENV="$SCRIPT_DIR/.env"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

if [ ! -f "$DOTENV" ]; then
    error "No existe $DOTENV"
    error "Ejecuta $SCRIPT_DIR/install.sh primero."
    exit 1
fi

set -a
# shellcheck disable=SC1090
source "$DOTENV"
set +a

: "${ROUTER_HOST:=127.0.0.1}"
: "${ROUTER_PORT:=4000}"
: "${CODEX_ADAPTER_HOST:=$ROUTER_HOST}"
: "${CODEX_ADAPTER_PORT:=4001}"
: "${CODEX_DEFAULT_MODEL:=deepseek-opus}"
: "${CODEX_REASONING_EFFORT:=low}"
: "${LITELLM_MASTER_KEY:=}"

if [ -z "$LITELLM_MASTER_KEY" ] || [[ "$LITELLM_MASTER_KEY" == *change-me* ]]; then
    error "LITELLM_MASTER_KEY no configurada en $DOTENV"
    exit 1
fi

if ! ss -tlnp 2>/dev/null | grep -q ":${ROUTER_PORT} " || \
   ! ss -tlnp 2>/dev/null | grep -q ":${CODEX_ADAPTER_PORT} "; then
    warn "Router o adaptador Codex no estan corriendo. Intentando arrancar ..."
    "$SCRIPT_DIR/start-router.sh"
fi

if ! command -v codex &>/dev/null; then
    error "'codex' no encontrado en PATH."
    error "Instala OpenAI Codex CLI antes de usar codex-mix."
    exit 1
fi

CODEX_BASE_URL="http://${CODEX_ADAPTER_HOST}:${CODEX_ADAPTER_PORT}/v1"

info "CODEX_BASE_URL=$CODEX_BASE_URL"
info "Modelo default: ${CODEX_DEFAULT_MODEL}"
echo ""

export OPENAI_BASE_URL="$CODEX_BASE_URL"
export OPENAI_API_KEY="$LITELLM_MASTER_KEY"

COMMON_ARGS=(
    --disable image_generation \
    -m "$CODEX_DEFAULT_MODEL" \
    -c "model_reasoning_effort=\"$CODEX_REASONING_EFFORT\"" \
    -c 'model_reasoning_summary="none"'
)

if [ "$#" -gt 0 ]; then
    case "$1" in
        exec|e|review)
            SUBCOMMAND="$1"
            shift
            exec codex --dangerously-bypass-approvals-and-sandbox "$SUBCOMMAND" "${COMMON_ARGS[@]}" "$@"
            ;;
    esac
fi

exec codex --dangerously-bypass-approvals-and-sandbox "${COMMON_ARGS[@]}" "$@"
